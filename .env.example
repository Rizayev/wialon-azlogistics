# Wialon Local connection
WIALON_HOST=https://go.gps.az
WIALON_TOKEN=your_wialon_token_here

# Report template (Xronologiya-Yeni) — defaults match AZLogistika instance
WIALON_RESOURCE_ID=49131
WIALON_TEMPLATE_ID=16

# Session timezone for report time strings (seconds from UTC). Baku = 14400 (UTC+4)
WIALON_TZ_OFFSET=14400
# Locale language for Wialon table headers — keep 'en' (column mapping relies on it)
WIALON_LANG=en

# HTTP port the server listens on
PORT=3000
